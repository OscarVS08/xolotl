<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@drawable/fondo_interfaz"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.main.usuario.mapas.VisualizarMapaActivity">

    <!-- ===== Botón Home ===== -->
    <FrameLayout
        android:id="@+id/btnHomeContainer"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginTop="50dp"
        android:layout_marginStart="30dp"
        android:background="@drawable/fondo_morado_circular"
        android:foreground="?attr/selectableItemBackgroundBorderless"
        android:layout_alignParentStart="true">

        <ImageButton
            android:id="@+id/btnHome"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:src="@drawable/home_morado"
            android:contentDescription="Volver al inicio"
            android:scaleType="centerCrop"/>
    </FrameLayout>

    <!-- ====== TÍTULO ====== -->
    <TextView
        android:id="@+id/txtTituloMascota"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Clínicas 24 horas"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textColor="@color/botonEmergencia"
        android:layout_marginStart="20dp"
        android:layout_marginTop="50dp"
        android:layout_toEndOf="@id/btnHomeContainer"/>

    <!-- ===== CONTENEDOR PRINCIPAL ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/txtTituloMascota"
        android:orientation="vertical"
        android:layout_margin="24dp">

        <!-- ===== RECUADRO AZUL ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="20dp"
            android:background="@drawable/rectangulosesion"
            android:elevation="6dp">

            <!-- ===== MAPA (CRECE AUTOMÁTICAMENTE) ===== -->
            <FrameLayout
                android:id="@+id/mapContainer"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="20dp" />

            <!-- ===== Nombre del dueño ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Nombre:"
                    android:textStyle="bold"
                    android:padding="12dp"
                    android:background="@drawable/campos_circulares"
                    android:backgroundTint="@android:color/white"
                    android:textColor="@android:color/black"/>

                <TextView
                    android:id="@+id/txtnombreDueno"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:padding="12dp"
                    android:background="@drawable/campos_circulares"
                    android:backgroundTint="#E0E0E0"
                    android:text="Ningún lugar seleccionado"
                    android:textColor="@android:color/black"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</RelativeLayout>