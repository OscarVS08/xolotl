<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@drawable/fondo_interfaz"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.main.usuario.NotificacionesActivity">

    <FrameLayout
        android:id="@+id/btnHomeContainer"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginTop="50dp"
        android:layout_marginStart="30dp"
        android:background="@drawable/fondo_morado_circular"
        android:foreground="?attr/selectableItemBackgroundBorderless"
        android:layout_alignParentStart="true">

        <ImageButton
            android:id="@+id/btnHome"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:src="@drawable/home_morado"
            android:contentDescription="Volver al inicio"
            android:scaleType="centerCrop"/>
    </FrameLayout>

    <!-- ====== TÍTULO ====== -->
    <TextView
        android:id="@+id/txtTituloMascota"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Notificaciones"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"
        android:layout_marginStart="20dp"
        android:layout_marginTop="50dp"
        android:layout_toEndOf="@id/btnHomeContainer"/>

    <!-- ===== Scroll con formulario ===== -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/txtTituloMascota"
        android:layout_marginTop="10dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_margin="24dp"
            android:padding="20dp"
            android:background="@drawable/rectangulosesion"
            android:paddingBottom="60dp"
            android:elevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layout_margin="24dp"
                android:padding="20dp"
                android:background="@drawable/fondo_logo_circular"
                android:paddingBottom="60dp"
                android:elevation="6dp">

                <!-- Texto descriptivo -->
                <TextView
                    android:id="@+id/txtDescripcion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Selecciona la frecuencia con la que se enviaran notificaciones de tus citas agendadas. La configuración se aplica a todas las citas
                    por igual. De forma predeterminada, se te enviara un recordatorio 24 horas antes de la asignada en la cita. Esta configuración son notificaciones adicionales"
                    android:textColor="@android:color/black"
                    android:textSize="18sp"
                    android:textAlignment="center"
                    android:layout_marginBottom="1dp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layout_margin="24dp"
                android:padding="20dp"
                android:background="@drawable/fondo_logo_circular"
                android:backgroundTint="@color/white"
                android:paddingBottom="60dp"
                android:elevation="6dp">

                <TextView
                    android:id="@+id/txtDescripcionHora"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="Horas de envío de mensajes:"
                    android:textColor="@android:color/black"
                    android:textSize="18sp"
                    android:textAlignment="center"
                    android:layout_marginBottom="1dp"
                    />

            </LinearLayout>

            <AutoCompleteTextView
                android:id="@+id/txtColor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapWords"
                android:maxLength="50"
                android:textColor="@android:color/black"
                android:textColorHint="#757575"
                android:background="@drawable/campos_circulares"
                android:layout_margin="24dp"
                android:padding="10dp"
                android:layout_marginBottom="10dp" />


        </LinearLayout>
    </ScrollView>
</RelativeLayout>
