<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@drawable/fondo_interfaz"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.main.usuario.EditarCitasActivity">

    <!-- ===== Botón Home ===== -->
    <FrameLayout
        android:id="@+id/btnHomeContainer"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginTop="50dp"
        android:layout_marginStart="30dp"
        android:background="@drawable/fondo_morado_circular"
        android:foreground="?attr/selectableItemBackgroundBorderless"
        android:layout_alignParentStart="true">

        <ImageButton
            android:id="@+id/btnHome"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:src="@drawable/home_morado"
            android:contentDescription="Volver al inicio"
            android:scaleType="centerCrop"/>
    </FrameLayout>

    <!-- ===== TÍTULO ====== -->
    <TextView
        android:id="@+id/txtTituloDesparasitacion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Editar de citas"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"
        android:layout_marginStart="20dp"
        android:layout_marginTop="50dp"
        android:layout_toEndOf="@id/btnHomeContainer"/>

    <!-- ===== Scroll con formulario ===== -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/txtTituloDesparasitacion"
        android:layout_marginTop="10dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== RECUADRO AZUL ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layout_margin="24dp"
                android:padding="20dp"
                android:background="@drawable/rectangulosesion"
                android:paddingBottom="60dp"
                android:elevation="6dp">

                <!-- AQUÍ VA TODO TU FORMULARIO (Sin cambiar nada) -->
                <TextView
                    android:id="@+id/txtNombreMascota"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Selecciona la mascota"
                    android:focusable="false"
                    android:focusableInTouchMode="false"
                    android:background="@drawable/campos_circulares"
                    android:padding="12dp"
                    android:textColor="@android:color/black"
                    android:textColorHint="#757575"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/txtRuac"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapWords"
                    android:textColor="@android:color/black"
                    android:textColorHint="#757575"
                    android:background="@drawable/campos_circulares"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp" />

                <AutoCompleteTextView
                    android:id="@+id/txtServicio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Servicio"
                    android:inputType="textCapWords"
                    android:textColor="@android:color/black"
                    android:textColorHint="#757575"
                    android:background="@drawable/campos_circulares"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp" />

                <EditText
                    android:id="@+id/txtFechaHora"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Fecha y hora (DD/MM/YYYY)"
                    android:focusable="false"
                    android:inputType="none"
                    android:textColor="@android:color/black"
                    android:textColorHint="#757575"
                    android:background="@drawable/campos_circulares"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp" />

                <EditText
                    android:id="@+id/txtNotas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Notas"
                    android:inputType="textCapWords"
                    android:textColor="@android:color/black"
                    android:textColorHint="#757575"
                    android:background="@drawable/campos_circulares"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp" />

            </LinearLayout>

            <!-- ===== BOTONES FUERA DEL RECUADRO AZUL ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginBottom="40dp">

                <!-- 🟦 ESPACIO VACÍO 33% -->
                <View
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"/>

                <!-- 🟦 ESPACIO VACÍO 33% -->
                <View
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"/>

                <!-- ✅ GUARDAR 33% -->
                <LinearLayout
                    android:id="@+id/btnGuardarCambios"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp"
                    android:background="@drawable/campos_circulares"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/aceptar_morado"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Guardar cambios"
                        android:textStyle="bold"
                        android:textColor="@android:color/black"/>
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</RelativeLayout>