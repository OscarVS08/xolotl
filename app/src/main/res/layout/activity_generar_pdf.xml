<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@drawable/fondo_interfaz"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.main.mascota.GenerarPdfActivity">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/btnHomeContainer"
        android:layout_width="55dp"
        android:layout_height="55dp"
        android:layout_marginTop="45dp"
        android:layout_marginStart="20dp"
        app:cardBackgroundColor="@color/rectanguloLogo"
        app:cardCornerRadius="27.5dp"
        app:cardElevation="8dp"
        app:strokeColor="@color/colorIntermedio"
        app:strokeWidth="2dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">
        <ImageButton
            android:id="@+id/btnHome"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/home_morado"
            android:contentDescription="Volver al inicio"
            android:padding="12dp"
            android:scaleType="centerInside" />
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardTituloMascota"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="20dp"
        app:cardBackgroundColor="@color/rectanguloLogo"
        app:cardCornerRadius="20dp"
        app:cardElevation="6dp"
        app:strokeColor="@color/colorIntermedio"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toTopOf="@id/btnHomeContainer"
        app:layout_constraintBottom_toBottomOf="@id/btnHomeContainer"
        app:layout_constraintStart_toEndOf="@id/btnHomeContainer"
        app:layout_constraintEnd_toEndOf="parent">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="Generación del carnet"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/black" />
    </com.google.android.material.card.MaterialCardView>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="15dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/btnHomeContainer"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="40dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginVertical="10dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="25dp"
                app:cardElevation="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:background="@drawable/rectangulosesion">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="20dp">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/imgFotoMascotaTop"
                            android:layout_width="110dp"
                            android:layout_height="110dp"
                            android:padding="2dp"
                            app:strokeColor="@color/colorIntermedio"
                            app:strokeWidth="2dp"
                            app:shapeAppearanceOverlay="@style/CircleImage"
                            android:scaleType="centerCrop"
                            android:src="@drawable/foto_blanco"
                            android:background="@color/botonRegistrarse" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="15dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Nombre"
                                android:textColor="@color/white"
                                android:textSize="12sp"
                                android:layout_marginStart="5dp"
                                android:layout_marginBottom="2dp"/>

                            <TextView
                                android:id="@+id/txtNombreMascotaTop"
                                android:layout_width="match_parent"
                                android:layout_height="50dp"
                                android:background="@drawable/campos_circulares"
                                android:gravity="center_vertical"
                                android:paddingHorizontal="15dp"
                                android:text="--"
                                android:textColor="@android:color/black"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="RUAC"
                                android:textColor="@color/white"
                                android:textSize="12sp"
                                android:layout_marginStart="5dp"
                                android:layout_marginTop="8dp"
                                android:layout_marginBottom="2dp"/>

                            <TextView
                                android:id="@+id/txtRuacTop"
                                android:layout_width="match_parent"
                                android:layout_height="40dp"
                                android:gravity="center_vertical"
                                android:paddingHorizontal="12dp"
                                android:text="--"
                                android:background="@drawable/campos_circulares"
                                android:textStyle="bold"
                                android:textColor="@color/black"
                                android:textSize="13sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Información General"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:layout_marginBottom="15dp"
                        android:textSize="15sp"/>

                    <TextView
                        android:id="@+id/txtnombreDueno"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:background="@drawable/campos_circulares"
                        android:backgroundTint="#E0E0E0"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="15dp"
                        android:text="--"
                        android:layout_marginBottom="12dp"
                        android:textColor="@android:color/black" />

                    <TextView
                        android:id="@+id/txtnumeroTelefonoDueno"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:background="@drawable/campos_circulares"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="15dp"
                        android:text="--"
                        android:layout_marginBottom="12dp"
                        android:textColor="@android:color/black" />

                    <TextView
                        android:id="@+id/txtnumTelAltDuen"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:background="@drawable/campos_circulares"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="15dp"
                        android:text="--"
                        android:layout_marginBottom="12dp"
                        android:textColor="@android:color/black" />

                    <TextView
                        android:id="@+id/txtFechaNacimiento"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:background="@drawable/campos_circulares"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="15dp"
                        android:text="--"
                        android:layout_marginBottom="12dp"
                        android:textColor="@android:color/black" />

                    <TextView
                        android:id="@+id/txtFechaAdopcion"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:background="@drawable/campos_circulares"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="15dp"
                        android:text="--"
                        android:layout_marginBottom="12dp"
                        android:textColor="@android:color/black" />

                    <TextView
                        android:id="@+id/txtEspecie"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:background="@drawable/campos_circulares"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="15dp"
                        android:text="--"
                        android:layout_marginBottom="12dp"
                        android:textColor="@android:color/black" />

                    <TextView
                        android:id="@+id/txtRaza"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:background="@drawable/campos_circulares"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="15dp"
                        android:text="--"
                        android:layout_marginBottom="12dp"
                        android:textColor="@android:color/black" />

                    <TextView
                        android:id="@+id/txtColor"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:background="@drawable/campos_circulares"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="15dp"
                        android:text="--"
                        android:layout_marginBottom="12dp"
                        android:textColor="@android:color/black" />

                    <TextView
                        android:id="@+id/txtSexo"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:background="@drawable/campos_circulares"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="15dp"
                        android:text="--"
                        android:layout_marginBottom="12dp"
                        android:textColor="@android:color/black" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">
                        <TextView
                            android:id="@+id/txtPeso"
                            android:layout_width="0dp"
                            android:layout_height="55dp"
                            android:layout_weight="1"
                            android:background="@drawable/campos_circulares"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="15dp"
                            android:text="--"
                            android:textColor="@android:color/black" />
                        <View android:layout_width="10dp" android:layout_height="1dp"/>
                        <TextView
                            android:id="@+id/txtEstatura"
                            android:layout_width="0dp"
                            android:layout_height="55dp"
                            android:layout_weight="1"
                            android:background="@drawable/campos_circulares"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="15dp"
                            android:text="--"
                            android:textColor="@android:color/black" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/txtAlergias"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:background="@drawable/campos_circulares"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="15dp"
                        android:text="--"
                        android:layout_marginBottom="12dp"
                        android:textColor="@android:color/black" />

                    <TextView
                        android:id="@+id/txtNotas"
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:background="@drawable/campos_circulares"
                        android:gravity="top"
                        android:padding="12dp"
                        android:text="--"
                        android:textColor="@android:color/black" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:paddingHorizontal="25dp"
                android:layout_marginTop="10dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnGenerarPdfContainer"
                    android:layout_width="180dp"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@android:color/white"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="6dp">

                    <LinearLayout
                        android:id="@+id/btnGenerarPdf"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:padding="12dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/pdf_morado"
                            android:layout_marginEnd="8dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Generar carnet"
                            android:textStyle="bold"
                            android:textColor="@android:color/black"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>