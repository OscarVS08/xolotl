<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@color/fondoPrincipal"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.main.mascota.GenerarPdfActivity">

    <!-- ===== BOTÓN HOME ===== -->
    <FrameLayout
        android:id="@+id/btnHomeContainer"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginTop="50dp"
        android:layout_marginStart="30dp"
        android:background="@drawable/fondo_morado_circular"
        android:foreground="?attr/selectableItemBackgroundBorderless"
        android:layout_alignParentStart="true">

        <ImageButton
            android:id="@+id/btnHome"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:src="@drawable/baseline_home_24"
            android:contentDescription="Volver al inicio"
            android:scaleType="centerCrop"/>
    </FrameLayout>

    <!-- ====== TÍTULO ====== -->
    <TextView
        android:id="@+id/txtTituloMascota"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Generación del carnet"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:layout_marginStart="20dp"
        android:layout_marginTop="50dp"
        android:layout_toEndOf="@id/btnHomeContainer"/>

    <!-- ===== Scroll con formulario ===== -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/txtTituloMascota"
        android:layout_marginTop="10dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_margin="24dp"
            android:padding="20dp"
            android:background="@drawable/rectangulosesion"
            android:paddingBottom="60dp"
            android:elevation="6dp">

            <!-- ===========================
                 TARJETA SUPERIOR: FOTO (amarilla redondeada) + DATOS A LA DERECHA
            ============================== -->
            <LinearLayout
                android:id="@+id/cardInfoMascota"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="8dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <!-- FOTO dentro de Frame para aplicar fondo redondeado y tint amarillo -->
                <FrameLayout
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/campos_circulares"
                    android:backgroundTint="@color/rectanguloLogo">

                    <ImageView
                        android:id="@+id/imgFotoMascotaTop"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:padding="6dp"
                        android:src="@drawable/baseline_add_a_photo_24"/>
                </FrameLayout>

                <!-- DATOS (Nombre y RUAC) -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <!-- Nombre: etiqueta (blanco) + valor (gris) -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Nombre"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:padding="8dp"
                        android:background="@drawable/campos_circulares"
                        android:backgroundTint="@android:color/white"
                        android:textColor="@android:color/black"/>

                    <TextView
                        android:id="@+id/txtNombreMascotaTop"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="10dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/campos_circulares"
                        android:backgroundTint="#E0E0E0"
                        android:text="--"
                        android:textSize="20sp"
                        android:textColor="@android:color/black"
                        android:layout_marginBottom="10dp"/>

                    <!-- RUAC: etiqueta (blanco) + valor (gris) -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="RUAC"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:padding="8dp"
                        android:background="@drawable/campos_circulares"
                        android:backgroundTint="@android:color/white"
                        android:textColor="@android:color/black"/>

                    <TextView
                        android:id="@+id/txtRuacTop"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="10dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/campos_circulares"
                        android:backgroundTint="#E0E0E0"
                        android:text="--"
                        android:textSize="16sp"
                        android:textColor="@android:color/black"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ===========================
                 FILAS: ETIQUETA (BLANCO redondeado) | VALOR (GRIS redondeado)
            ============================== -->
            <!-- Nombre del dueño -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Dueño:"
                    android:textStyle="bold"
                    android:padding="12dp"
                    android:background="@drawable/campos_circulares"
                    android:backgroundTint="@android:color/white"
                    android:textColor="@android:color/black"/>

                <TextView
                    android:id="@+id/txtnombreDueno"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:padding="12dp"
                    android:background="@drawable/campos_circulares"
                    android:backgroundTint="#E0E0E0"
                    android:text="--"
                    android:textColor="@android:color/black"/>
            </LinearLayout>

            <!-- Telefonos de contacto -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Contacto del dueño:"
                    android:textStyle="bold"
                    android:padding="12dp"
                    android:background="@drawable/campos_circulares"
                    android:backgroundTint="@android:color/white"
                    android:textColor="@android:color/black"/>

                <TextView
                    android:id="@+id/txtnumeroTelefonoDueno"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:padding="12dp"
                    android:background="@drawable/campos_circulares"
                    android:backgroundTint="#E0E0E0"
                    android:text="--"
                    android:textColor="@android:color/black"/>
            </LinearLayout>

            <!-- Fecha adopción -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Contacto alternativo:"
                    android:textStyle="bold"
                    android:padding="12dp"
                    android:background="@drawable/campos_circulares"
                    android:backgroundTint="@android:color/white"
                    android:textColor="@android:color/black"/>

                <TextView
                    android:id="@+id/txtnumTelAltDuen"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:padding="12dp"
                    android:background="@drawable/campos_circulares"
                    android:backgroundTint="#E0E0E0"
                    android:text="--"
                    android:textColor="@android:color/black"/>
            </LinearLayout>

            <!-- Fecha adopción -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Fecha adopción:"
                    android:textStyle="bold"
                    android:padding="12dp"
                    android:background="@drawable/campos_circulares"
                    android:backgroundTint="@android:color/white"
                    android:textColor="@android:color/black"/>

                <TextView
                    android:id="@+id/txtFechaAdopcion"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:padding="12dp"
                    android:background="@drawable/campos_circulares"
                    android:backgroundTint="#E0E0E0"
                    android:text="--"
                    android:textColor="@android:color/black"/>
            </LinearLayout>

            <!-- Especie -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Especie:"
                    android:textStyle="bold"
                    android:padding="12dp"
                    android:background="@drawable/campos_circulares"
                    android:backgroundTint="@android:color/white"
                    android:textColor="@android:color/black"/>

                <TextView
                    android:id="@+id/txtEspecie"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:padding="12dp"
                    android:background="@drawable/campos_circulares"
                    android:backgroundTint="#E0E0E0"
                    android:text="--"
                    android:textColor="@android:color/black"/>
            </LinearLayout>

            <!-- Raza -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Raza:"
                    android:textStyle="bold"
                    android:padding="12dp"
                    android:background="@drawable/campos_circulares"
                    android:backgroundTint="@android:color/white"
                    android:textColor="@android:color/black"/>

                <TextView
                    android:id="@+id/txtRaza"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:padding="12dp"
                    android:background="@drawable/campos_circulares"
                    android:backgroundTint="#E0E0E0"
                    android:text="--"
                    android:textColor="@android:color/black"/>
            </LinearLayout>

            <!-- Color -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Color:"
                    android:textStyle="bold"
                    android:padding="12dp"
                    android:background="@drawable/campos_circulares"
                    android:backgroundTint="@android:color/white"
                    android:textColor="@android:color/black"/>

                <TextView
                    android:id="@+id/txtColor"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:padding="12dp"
                    android:background="@drawable/campos_circulares"
                    android:backgroundTint="#E0E0E0"
                    android:text="--"
                    android:textColor="@android:color/black"/>
            </LinearLayout>

            <!-- Sexo -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Sexo:"
                    android:textStyle="bold"
                    android:padding="12dp"
                    android:background="@drawable/campos_circulares"
                    android:backgroundTint="@android:color/white"
                    android:textColor="@android:color/black"/>

                <TextView
                    android:id="@+id/txtSexo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:padding="12dp"
                    android:background="@drawable/campos_circulares"
                    android:backgroundTint="#E0E0E0"
                    android:text="--"
                    android:textColor="@android:color/black"/>
            </LinearLayout>

            <!-- Peso -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Peso:"
                    android:textStyle="bold"
                    android:padding="12dp"
                    android:background="@drawable/campos_circulares"
                    android:backgroundTint="@android:color/white"
                    android:textColor="@android:color/black"/>

                <TextView
                    android:id="@+id/txtPeso"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:padding="12dp"
                    android:background="@drawable/campos_circulares"
                    android:backgroundTint="#E0E0E0"
                    android:text="--"
                    android:textColor="@android:color/black"/>
            </LinearLayout>

            <!-- Estatura -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Estatura:"
                    android:textStyle="bold"
                    android:padding="12dp"
                    android:background="@drawable/campos_circulares"
                    android:backgroundTint="@android:color/white"
                    android:textColor="@android:color/black"/>

                <TextView
                    android:id="@+id/txtEstatura"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:padding="12dp"
                    android:background="@drawable/campos_circulares"
                    android:backgroundTint="#E0E0E0"
                    android:text="--"
                    android:textColor="@android:color/black"/>
            </LinearLayout>

            <!-- Alergias -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Alergias:"
                    android:textStyle="bold"
                    android:padding="12dp"
                    android:background="@drawable/campos_circulares"
                    android:backgroundTint="@android:color/white"
                    android:textColor="@android:color/black"/>

                <TextView
                    android:id="@+id/txtAlergias"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:padding="12dp"
                    android:background="@drawable/campos_circulares"
                    android:backgroundTint="#E0E0E0"
                    android:text="--"
                    android:textColor="@android:color/black"/>
            </LinearLayout>

            <!-- Notas (etiqueta arriba, valor caja gris abajo) -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Notas:"
                android:textStyle="bold"
                android:padding="12dp"
                android:background="@drawable/campos_circulares"
                android:backgroundTint="@android:color/white"
                android:textColor="@android:color/black"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/txtNotas"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:padding="12dp"
                android:background="@drawable/campos_circulares"
                android:backgroundTint="#E0E0E0"
                android:text="--"
                android:textColor="@android:color/black"
                android:gravity="top"
                android:layout_marginBottom="12dp"/>

            <!-- Botón para generar PDF -->
            <ImageView
                android:id="@+id/btnGenerarPdf"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:layout_gravity="center|right"
                android:src="@drawable/baseline_picture_as_pdf_24"
                android:contentDescription="Boton para Generar PDF"
                android:padding="20dp"
                android:background="@drawable/campos_circulares"
                android:backgroundTint="@color/rectanguloLogo"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="20dp"
                />

        </LinearLayout>
    </ScrollView>
</RelativeLayout>
