<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardCornerRadius="35dp"
    app:cardElevation="25dp"
    app:strokeWidth="2dp"
    app:strokeColor="#66FFFFFF"> <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="35dp"
    android:background="@drawable/rectangulosesion"
    android:gravity="center">

    <View
        android:layout_width="50dp"
        android:layout_height="3dp"
        android:background="#99FFFFFF"
        android:layout_marginBottom="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="100dp"
        android:layout_height="100dp"
        app:cardCornerRadius="50dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#1AFFFFFF"
        app:strokeWidth="1dp"
        app:strokeColor="#4DFFFFFF"
        android:layout_marginBottom="20dp">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/logo_a_color"
            android:padding="15dp"
            android:scaleType="centerInside"
            android:alpha="0.9"/>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Proyecto Xólotl"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:letterSpacing="0.06"
        android:includeFontPadding="false"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Orgullosamente politécnico"
        android:textSize="13sp"
        android:textColor="#B3FFFFFF"
        android:textAllCaps="true"
        android:letterSpacing="0.15"
        android:layout_marginBottom="20dp"
        android:layout_gravity="center_horizontal"
        android:textAlignment="center"
        android:includeFontPadding="false"/>

    <View
        android:layout_width=" match_parent"
        android:layout_height="0.5dp"
        android:background="#26FFFFFF"
        android:layout_marginHorizontal="30dp"
        android:layout_marginBottom="24dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:fadeScrollbars="true"
        android:scrollbarThumbVertical="@android:color/white"
        android:fadingEdgeLength="30dp"
        android:requiresFadingEdge="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Este proyecto representa meses de esfuerzo inquebrantable, aprendizaje profundo y dedicación absoluta al desarrollo móvil.\n\nMi más sincero agradecimiento a mi familia y amigos, pilares fundamentales en las noches de código, y a cada persona que depositó su confianza en la visión de Xólotl para transformar el cuidado animal."
                android:textColor="@color/white"
                android:textSize="16sp"
                android:lineSpacingMultiplier="1.4"
                android:textAlignment="center"
                android:alpha="0.95"/>

            <View
                android:layout_width="80dp"
                android:layout_height="0.5dp"
                android:background="#26FFFFFF"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Desarrollado con pasión por:"
                android:textColor="#99FFFFFF"
                android:textSize="13sp"
                android:textAlignment="center"
                android:textStyle="italic"
                android:letterSpacing="0.02"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Oscar Vaquero Santos"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textAlignment="center"
                android:letterSpacing="0.01"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="IPN - ESCOM 2026"
                android:textColor="#CCFFFFFF"
                android:textSize="14sp"
                android:textAlignment="center"
                android:layout_marginBottom="15dp"
                android:letterSpacing="0.05"/>
        </LinearLayout>
    </ScrollView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/btnCerrarEasterEggContainer"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="15dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#F2FFFFFF"
        app:strokeWidth="1dp"
        app:strokeColor="#33000000"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="¡Gracias! ❤️"
            android:gravity="center"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:letterSpacing="0.03"/>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
</com.google.android.material.card.MaterialCardView>