<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardCornerRadius="35dp"
    app:cardElevation="25dp"
    app:strokeWidth="2dp"
    app:strokeColor="#66FFFFFF"> <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="40dp"
    android:background="@drawable/rectangulosesion"
    android:gravity="center">



    <com.google.android.material.card.MaterialCardView
        android:layout_width="100dp"
        android:layout_height="100dp"
        app:cardCornerRadius="50dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#9176cf"
        app:strokeWidth="1dp"
        app:strokeColor="#4DFFFFFF"
        android:layout_marginBottom="20dp">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/logo_monocromatico"
            android:scaleType="centerInside"
            android:alpha="1"/>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Xólotl"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:letterSpacing="0.06"
        android:includeFontPadding="false"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Orgullosamente politécnico"
        android:textSize="13sp"
        android:textColor="#B3FFFFFF"
        android:textAllCaps="true"
        android:letterSpacing="0.15"
        android:layout_marginBottom="20dp"
        android:layout_gravity="center_horizontal"
        android:textAlignment="center"
        android:includeFontPadding="false"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#26FFFFFF"
        android:layout_marginHorizontal="30dp"
        android:layout_marginBottom="24dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:fadeScrollbars="true"
        android:scrollbarThumbVertical="@android:color/white"
        android:fadingEdgeLength="30dp"
        android:requiresFadingEdge="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:alpha="0.95"
                android:lineSpacingMultiplier="1.4"
                android:text="Este proyecto representa la culminación de una etapa llena de retos y obstáculos que pondrían a prueba incluso a los más templados, un viaje que solo termina cuando la disciplina supera a la desidia.\n\nGracias a todos aquellos que creyeron en esta misión, mi familia, mis amigos, mi hermana...\n\nPorque sin su apoyo incondicional este proyecto no habría sido posible y es gracias a ellos que ahora puedo demostrar que la ingeniería no solo resguarda las necesidades humanas."
                android:justificationMode="inter_word"
                android:textColor="@color/white"
                android:textSize="16sp" />

            <View
                android:layout_width="80dp"
                android:layout_height="0.5dp"
                android:background="#26FFFFFF"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Desarrollado con todo el corazón por:"
                android:textColor="#99FFFFFF"
                android:textSize="11sp"
                android:textAlignment="center"
                android:textStyle="italic"
                android:letterSpacing="0.02"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Diego Isaac Guerrero Sánchez"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textAlignment="center"
                android:letterSpacing="0.01"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="IPN - ESCOM 2026"
                android:textColor="#CCFFFFFF"
                android:textSize="14sp"
                android:textAlignment="center"
                android:layout_marginBottom="15dp"
                android:letterSpacing="0.05"/>
        </LinearLayout>
    </ScrollView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/btnCerrarEasterEggContainer"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="15dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#F2FFFFFF"
        app:strokeWidth="1dp"
        app:strokeColor="#33000000"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="🐾💗 ¡Gracias! 💗🐾"
            android:gravity="center"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:letterSpacing="0.03"/>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
</com.google.android.material.card.MaterialCardView>