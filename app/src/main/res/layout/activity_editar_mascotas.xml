<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@drawable/fondo_interfaz"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.main.mascota.EditarMascotasActivity">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/btnHomeContainer"
        android:layout_width="55dp"
        android:layout_height="55dp"
        android:layout_marginTop="45dp"
        android:layout_marginStart="20dp"
        app:cardBackgroundColor="@color/rectanguloLogo"
        app:cardCornerRadius="27.5dp"
        app:cardElevation="8dp"
        app:strokeColor="@color/colorIntermedio"
        app:strokeWidth="2dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">
        <ImageButton
            android:id="@+id/btnHome"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/home_morado"
            android:contentDescription="Volver al inicio"
            android:padding="12dp"
            android:scaleType="centerInside" />
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardTituloMascota"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="20dp"
        app:cardBackgroundColor="@color/rectanguloLogo"
        app:cardCornerRadius="20dp"
        app:cardElevation="6dp"
        app:strokeColor="@color/colorIntermedio"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toTopOf="@id/btnHomeContainer"
        app:layout_constraintBottom_toBottomOf="@id/btnHomeContainer"
        app:layout_constraintStart_toEndOf="@id/btnHomeContainer"
        app:layout_constraintEnd_toEndOf="parent">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="Editar mascota"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/black" />
    </com.google.android.material.card.MaterialCardView>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="15dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/btnHomeContainer"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="40dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginVertical="10dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="25dp"
                app:cardElevation="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:background="@drawable/rectangulosesion">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="20dp">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/imgFotoMascotaTop"
                            android:layout_width="110dp"
                            android:layout_height="110dp"
                            android:padding="2dp"
                            app:strokeColor="@color/colorIntermedio"
                            app:strokeWidth="2dp"
                            app:shapeAppearanceOverlay="@style/CircleImage"
                            android:scaleType="centerCrop"
                            android:src="@drawable/foto_blanco"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="@color/botonRegistrarse" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="15dp">

                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/layoutNombreMascotaTop"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                app:hintEnabled="false"
                                app:errorEnabled="true"
                                app:endIconMode="custom"
                                app:endIconDrawable="@drawable/baseline_edit_24"
                                app:endIconTint="@color/moradoSubtitulo"
                                app:errorIconDrawable="@null">
                                <EditText
                                    android:id="@+id/txtNombreMascotaTop"
                                    android:layout_width="match_parent"
                                    android:layout_height="50dp"
                                    android:hint="Nombre"
                                    android:background="@drawable/campos_circulares"
                                    android:paddingHorizontal="15dp"
                                    android:textColor="@android:color/black"
                                    android:inputType="textCapWords" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <TextView
                                android:id="@+id/txtRuacTop"
                                android:layout_width="match_parent"
                                android:layout_height="40dp"
                                android:gravity="center_vertical"
                                android:paddingHorizontal="12dp"
                                android:text="--"
                                android:background="@drawable/campos_circulares"
                                android:textStyle="bold"
                                android:textColor="@color/black"
                                android:textSize="13sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Información General"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:layout_marginBottom="15dp"
                        android:textSize="15sp"/>

                    <TextView
                        android:id="@+id/txtnombreDueno"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:background="@drawable/campos_circulares"
                        android:backgroundTint="#E0E0E0"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="15dp"
                        android:text="--"
                        android:layout_marginBottom="12dp"
                        android:textColor="@android:color/black" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutTelefonoDueno"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:hintEnabled="false"
                        app:errorEnabled="true"
                        app:endIconMode="custom"
                        app:endIconDrawable="@drawable/baseline_edit_24"
                        app:endIconTint="@color/moradoSubtitulo">
                        <EditText
                            android:id="@+id/txtnumeroTelefonoDueno"
                            android:layout_width="match_parent"
                            android:layout_height="55dp"
                            android:hint="Contacto del dueño"
                            android:background="@drawable/campos_circulares"
                            android:paddingHorizontal="15dp"
                            android:inputType="phone"
                            android:textColor="@android:color/black" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutTelAlt"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:hintEnabled="false"
                        app:errorEnabled="true"
                        app:endIconMode="custom"
                        app:endIconDrawable="@drawable/baseline_edit_24"
                        app:endIconTint="@color/moradoSubtitulo">
                        <EditText
                            android:id="@+id/txtnumTelAltDuen"
                            android:layout_width="match_parent"
                            android:layout_height="55dp"
                            android:hint="Contacto alternativo"
                            android:background="@drawable/campos_circulares"
                            android:paddingHorizontal="15dp"
                            android:inputType="phone"
                            android:textColor="@android:color/black" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutFechaNacimiento"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:hintEnabled="false"
                        app:errorEnabled="true"
                        app:endIconTint="@color/moradoSubtitulo">
                        <AutoCompleteTextView
                            android:id="@+id/txtFechaNacimiento"
                            android:layout_width="match_parent"
                            android:layout_height="55dp"
                            android:hint="Fecha de nacimiento"
                            android:background="@drawable/campos_circulares"
                            android:paddingHorizontal="15dp"
                            android:textColor="@android:color/black"
                            android:inputType="none" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutFechaAdopcion"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:hintEnabled="false"
                        app:errorEnabled="true"
                        app:endIconTint="@color/moradoSubtitulo">
                        <AutoCompleteTextView
                            android:id="@+id/txtFechaAdopcion"
                            android:layout_width="match_parent"
                            android:layout_height="55dp"
                            android:hint="Fecha de adopción"
                            android:background="@drawable/campos_circulares"
                            android:paddingHorizontal="15dp"
                            android:textColor="@android:color/black"
                            android:inputType="none" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutEspecie"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:hintEnabled="false"
                        app:errorEnabled="true"
                        app:endIconTint="@color/moradoSubtitulo">
                        <AutoCompleteTextView
                            android:id="@+id/txtEspecie"
                            android:layout_width="match_parent"
                            android:layout_height="55dp"
                            android:hint="Especie"
                            android:background="@drawable/campos_circulares"
                            android:paddingHorizontal="15dp"
                            android:textColor="@android:color/black"
                            android:inputType="none" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutRaza"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:hintEnabled="false"
                        app:errorEnabled="true"
                        app:endIconTint="@color/moradoSubtitulo">
                        <AutoCompleteTextView
                            android:id="@+id/txtRaza"
                            android:layout_width="match_parent"
                            android:layout_height="55dp"
                            android:hint="Raza"
                            android:background="@drawable/campos_circulares"
                            android:paddingHorizontal="15dp"
                            android:textColor="@android:color/black"
                            android:inputType="none" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutRazaOtro"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        app:hintEnabled="false"
                        app:errorEnabled="true"
                        android:layout_marginTop="-10dp">
                        <EditText
                            android:id="@+id/txtRazaOtro"
                            android:layout_width="match_parent"
                            android:layout_height="55dp"
                            android:hint="Escribe la raza"
                            android:background="@drawable/campos_circulares"
                            android:paddingHorizontal="15dp"
                            android:textColor="@android:color/black"
                            android:inputType="textCapWords" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutColor"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:hintEnabled="false"
                        app:errorEnabled="true"
                        app:endIconTint="@color/moradoSubtitulo">
                        <AutoCompleteTextView
                            android:id="@+id/txtColor"
                            android:layout_width="match_parent"
                            android:layout_height="55dp"
                            android:hint="Color"
                            android:background="@drawable/campos_circulares"
                            android:paddingHorizontal="15dp"
                            android:textColor="@android:color/black"
                            android:inputType="none" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutOtroColor"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        app:hintEnabled="false"
                        app:errorEnabled="true"
                        android:layout_marginTop="-10dp">
                        <EditText
                            android:id="@+id/txtOtroColor"
                            android:layout_width="match_parent"
                            android:layout_height="55dp"
                            android:hint="Especifica el color"
                            android:background="@drawable/campos_circulares"
                            android:paddingHorizontal="15dp"
                            android:textColor="@android:color/black"
                            android:inputType="textCapWords" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutSexo"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:hintEnabled="false"
                        app:errorEnabled="true"
                        app:endIconTint="@color/moradoSubtitulo">
                        <AutoCompleteTextView
                            android:id="@+id/txtSexo"
                            android:layout_width="match_parent"
                            android:layout_height="55dp"
                            android:hint="Sexo"
                            android:background="@drawable/campos_circulares"
                            android:paddingHorizontal="15dp"
                            android:textColor="@android:color/black"
                            android:inputType="none" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/layoutPeso"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            app:hintEnabled="false"
                            app:errorEnabled="true"
                            app:endIconMode="custom"
                            app:endIconDrawable="@drawable/baseline_edit_24"
                            app:endIconTint="@color/moradoSubtitulo">
                            <EditText
                                android:id="@+id/txtPeso"
                                android:layout_width="match_parent"
                                android:layout_height="55dp"
                                android:hint="Peso (kg)"
                                android:inputType="numberDecimal"
                                android:background="@drawable/campos_circulares"
                                android:paddingHorizontal="15dp"
                                android:textColor="@android:color/black" />
                        </com.google.android.material.textfield.TextInputLayout>
                        <View android:layout_width="10dp" android:layout_height="1dp"/>
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/layoutEstatura"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            app:hintEnabled="false"
                            app:errorEnabled="true"
                            app:endIconMode="custom"
                            app:endIconDrawable="@drawable/baseline_edit_24"
                            app:endIconTint="@color/moradoSubtitulo">
                            <EditText
                                android:id="@+id/txtEstatura"
                                android:layout_width="match_parent"
                                android:layout_height="55dp"
                                android:hint="Estatura (cm)"
                                android:inputType="numberDecimal"
                                android:background="@drawable/campos_circulares"
                                android:paddingHorizontal="15dp"
                                android:textColor="@android:color/black" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutAlergias"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:hintEnabled="false"
                        app:errorEnabled="true"
                        app:endIconMode="custom"
                        app:endIconDrawable="@drawable/baseline_edit_24"
                        app:endIconTint="@color/moradoSubtitulo">
                        <EditText
                            android:id="@+id/txtAlergias"
                            android:layout_width="match_parent"
                            android:layout_height="55dp"
                            android:hint="Alergias"
                            android:background="@drawable/campos_circulares"
                            android:paddingHorizontal="15dp"
                            android:textColor="@android:color/black" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutNotas"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:hintEnabled="false"
                        app:errorEnabled="true"
                        app:endIconMode="custom"
                        app:endIconDrawable="@drawable/baseline_edit_24"
                        app:endIconTint="@color/moradoSubtitulo">
                        <EditText
                            android:id="@+id/txtNotas"
                            android:layout_width="match_parent"
                            android:layout_height="100dp"
                            android:hint="Notas adicionales"
                            android:gravity="top"
                            android:inputType="textMultiLine"
                            android:background="@drawable/campos_circulares"
                            android:padding="12dp"
                            android:textColor="@android:color/black" />
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:paddingHorizontal="25dp"
                android:layout_marginTop="10dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnGuardarCambiosContainer"
                    android:layout_width="160dp"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@android:color/white"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="6dp">

                    <LinearLayout
                        android:id="@+id/btnAceptarMorado"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:padding="12dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/aceptar_morado"
                            android:layout_marginEnd="8dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Guardar"
                            android:textStyle="bold"
                            android:textColor="@android:color/black"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>