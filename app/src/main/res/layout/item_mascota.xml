<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="20dp"
    app:cardElevation="6dp"
    app:strokeColor="@color/colorIntermedio"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:background="@drawable/rectangulosesion"
        android:orientation="horizontal"
        android:padding="12dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imgMascota"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_gravity="center_vertical"
            android:padding="2dp"
            android:scaleType="centerCrop"
            android:src="@drawable/foto_blanco"
            app:shapeAppearanceOverlay="@style/CircleImage"
            app:strokeColor="@color/rectanguloLogo"
            app:strokeWidth="2dp"
            android:background="@color/botonRegistrarse" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginStart="16dp"
            android:orientation="vertical"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/txtNombreMascotaItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nombre Mascota"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:ellipsize="end"
                android:maxLines="1" />

            <TextView
                android:id="@+id/txtInfoMascotaItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Información detallada"
                android:textColor="@android:color/white"
                android:textSize="13sp"
                android:layout_marginTop="2dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="end|bottom"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btnEliminarMascota"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/baseline_delete_24"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="#D32F2F"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    android:contentDescription="Eliminar" />

                <View android:layout_width="8dp" android:layout_height="0dp"/>

                <ImageButton
                    android:id="@+id/btnEditarMascota"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/baseline_edit_24"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="@color/white"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    android:contentDescription="Editar" />

                <View android:layout_width="8dp" android:layout_height="0dp"/>

                <ImageButton
                    android:id="@+id/btnPdfMascota"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/baseline_picture_as_pdf_24"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="@color/white"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    android:contentDescription="PDF" />

            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>