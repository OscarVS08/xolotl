<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/fondo_interfaz"
    tools:context=".ui.main.usuario.EditarPerfilActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="40dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnHomeContainer"
            android:layout_width="55dp"
            android:layout_height="55dp"
            android:layout_marginTop="45dp"
            android:layout_marginStart="20dp"
            app:cardBackgroundColor="@color/rectanguloLogo"
            app:cardCornerRadius="27.5dp"
            app:cardElevation="8dp"
            app:strokeColor="@color/colorIntermedio"
            app:strokeWidth="2dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent">
            <ImageButton
                android:id="@+id/btnHome"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/home_morado"
                android:contentDescription="Volver al inicio"
                android:padding="12dp"
                android:scaleType="centerInside" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardTituloMascota"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="20dp"
            app:cardBackgroundColor="@color/rectanguloLogo"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            app:strokeColor="@color/colorIntermedio"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toTopOf="@id/btnHomeContainer"
            app:layout_constraintBottom_toBottomOf="@id/btnHomeContainer"
            app:layout_constraintStart_toEndOf="@id/btnHomeContainer"
            app:layout_constraintEnd_toEndOf="parent">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="Editar Perfil"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@android:color/black" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:id="@+id/contenedorFormulario"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="25dp"
            android:background="@drawable/rectangulosesion"
            android:orientation="vertical"
            android:padding="25dp"
            android:elevation="6dp"
            app:layout_constraintTop_toBottomOf="@+id/cardTituloMascota"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintWidth_percent="0.90">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CURP (No editable)"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginBottom="5dp"
                android:layout_marginStart="5dp"/>

            <TextView
                android:id="@+id/txtCurp"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:background="@drawable/campos_circulares"
                android:backgroundTint="#E0E0E0"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp"
                android:text="--"
                android:textColor="@android:color/darker_gray"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Datos personales"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="16dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutNombre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:hintEnabled="false"
                app:errorEnabled="true"
                app:errorIconDrawable="@null"
                app:endIconMode="custom"
                app:endIconDrawable="@drawable/baseline_edit_24"
                app:endIconTint="@color/moradoSubtitulo">
                <EditText
                    android:id="@+id/txtNombre"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:hint="Nombre(s)"
                    android:inputType="textCapWords"
                    android:background="@drawable/campos_circulares"
                    android:paddingHorizontal="20dp"
                    android:textColor="@android:color/black" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutApellidoP"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:hintEnabled="false"
                app:errorEnabled="true"
                app:errorIconDrawable="@null"
                app:endIconMode="custom"
                app:endIconDrawable="@drawable/baseline_edit_24"
                app:endIconTint="@color/moradoSubtitulo">
                <EditText
                    android:id="@+id/txtApellidoP"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:hint="Apellido paterno"
                    android:inputType="textCapWords"
                    android:background="@drawable/campos_circulares"
                    android:paddingHorizontal="20dp"
                    android:textColor="@android:color/black" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutApellidoM"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:hintEnabled="false"
                app:errorEnabled="true"
                app:errorIconDrawable="@null"
                app:endIconMode="custom"
                app:endIconDrawable="@drawable/baseline_edit_24"
                app:endIconTint="@color/moradoSubtitulo">
                <EditText
                    android:id="@+id/txtApellidoM"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:hint="Apellido materno"
                    android:inputType="textCapWords"
                    android:background="@drawable/campos_circulares"
                    android:paddingHorizontal="20dp"
                    android:textColor="@android:color/black" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutTelefono"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:hintEnabled="false"
                app:errorEnabled="true"
                app:errorIconDrawable="@null"
                app:endIconMode="custom"
                app:endIconDrawable="@drawable/baseline_edit_24"
                app:endIconTint="@color/moradoSubtitulo">
                <EditText
                    android:id="@+id/txtTelefono"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:hint="Teléfono"
                    android:inputType="phone"
                    android:maxLength="10"
                    android:background="@drawable/campos_circulares"
                    android:paddingHorizontal="20dp"
                    android:textColor="@android:color/black" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutTelefonoAlt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:hintEnabled="false"
                app:errorEnabled="true"
                app:errorIconDrawable="@null"
                app:endIconMode="custom"
                app:endIconDrawable="@drawable/baseline_edit_24"
                app:endIconTint="@color/moradoSubtitulo">
                <EditText
                    android:id="@+id/txtTelefonoAlt"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:hint="Teléfono alternativo"
                    android:inputType="phone"
                    android:maxLength="10"
                    android:background="@drawable/campos_circulares"
                    android:paddingHorizontal="20dp"
                    android:textColor="@android:color/black" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Datos de residencia"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutCalle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:hintEnabled="false"
                app:errorEnabled="true"
                app:errorIconDrawable="@null"
                app:endIconMode="custom"
                app:endIconDrawable="@drawable/baseline_edit_24"
                app:endIconTint="@color/moradoSubtitulo">
                <EditText
                    android:id="@+id/txtCalle"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:hint="Calle"
                    android:inputType="textCapWords"
                    android:background="@drawable/campos_circulares"
                    android:paddingHorizontal="20dp"
                    android:textColor="@android:color/black" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutNumero"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:hintEnabled="false"
                app:errorEnabled="true"
                app:errorIconDrawable="@null"
                app:endIconMode="custom"
                app:endIconDrawable="@drawable/baseline_edit_24"
                app:endIconTint="@color/moradoSubtitulo">
                <EditText
                    android:id="@+id/txtNumero"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:hint="Número"
                    android:inputType="text"
                    android:background="@drawable/campos_circulares"
                    android:paddingHorizontal="20dp"
                    android:textColor="@android:color/black" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutColonia"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:hintEnabled="false"
                app:errorEnabled="true"
                app:errorIconDrawable="@null"
                app:endIconMode="custom"
                app:endIconDrawable="@drawable/baseline_edit_24"
                app:endIconTint="@color/moradoSubtitulo">
                <EditText
                    android:id="@+id/txtColonia"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:hint="Colonia"
                    android:inputType="textCapWords"
                    android:background="@drawable/campos_circulares"
                    android:paddingHorizontal="20dp"
                    android:textColor="@android:color/black" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutAlcaldia"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:hintEnabled="false"
                app:errorEnabled="true"
                app:errorIconDrawable="@null"
                app:endIconMode="custom"
                app:endIconDrawable="@drawable/baseline_edit_24"
                app:endIconTint="@color/moradoSubtitulo">
                <EditText
                    android:id="@+id/txtAlcaldia"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:hint="Alcaldía / Municipio"
                    android:inputType="textCapWords"
                    android:background="@drawable/campos_circulares"
                    android:paddingHorizontal="20dp"
                    android:textColor="@android:color/black" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutCodigoPostal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:hintEnabled="false"
                app:errorEnabled="true"
                app:errorIconDrawable="@null"
                app:endIconMode="custom"
                app:endIconDrawable="@drawable/baseline_edit_24"
                app:endIconTint="@color/moradoSubtitulo">
                <EditText
                    android:id="@+id/txtCodigoPostal"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:hint="Código postal (5 dígitos)"
                    android:inputType="number"
                    android:maxLength="5"
                    android:background="@drawable/campos_circulares"
                    android:paddingHorizontal="20dp"
                    android:textColor="@android:color/black" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Datos de seguridad"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutContrasena"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:hintEnabled="false"
                app:errorEnabled="true"
                app:errorIconDrawable="@null">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:background="@drawable/campos_circulares">
                    <EditText
                        android:id="@+id/txtContrasena"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:hint="Nueva contraseña"
                        android:inputType="textPassword"
                        android:paddingHorizontal="20dp"
                        android:textColor="@android:color/black" />
                    <ImageButton
                        android:id="@+id/btnToggleContrasena"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="8dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_eye_closed"
                        android:contentDescription="Mostrar u ocultar" />
                </RelativeLayout>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutConfirmarContrasena"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:hintEnabled="false"
                app:errorEnabled="true"
                app:errorIconDrawable="@null">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:background="@drawable/campos_circulares">
                    <EditText
                        android:id="@+id/txtConfirmarContrasena"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:hint="Confirmar contraseña"
                        android:inputType="textPassword"
                        android:paddingHorizontal="20dp"
                        android:textColor="@android:color/black" />
                    <ImageButton
                        android:id="@+id/btnToggleConfirmarContrasena"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="8dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_eye_closed"
                        android:contentDescription="Mostrar u ocultar" />
                </RelativeLayout>
            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="30dp"
            app:layout_constraintTop_toBottomOf="@id/contenedorFormulario"
            app:layout_constraintStart_toStartOf="@id/contenedorFormulario"
            app:layout_constraintEnd_toEndOf="@id/contenedorFormulario">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnEliminarCuentaContainer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="10dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:id="@+id/btnEliminarCuenta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:padding="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/borrar_morado"
                        android:layout_marginEnd="8dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Borrar cuenta"
                        android:textStyle="bold"
                        android:textColor="@android:color/black"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnGuardarCambiosContainer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:id="@+id/btnGuardarCambios"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:padding="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/aceptar_morado"
                        android:layout_marginEnd="8dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Guardar"
                        android:textStyle="bold"
                        android:textColor="@android:color/black"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>