<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@drawable/fondo_interfaz"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.main.mascota.AgregarMascotaActivity">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/btnHomeContainer"
        android:layout_width="55dp"
        android:layout_height="55dp"
        android:layout_marginTop="45dp"
        android:layout_marginStart="20dp"
        app:cardBackgroundColor="@color/rectanguloLogo"
        app:cardCornerRadius="27.5dp"
        app:cardElevation="8dp"
        app:strokeColor="@color/colorIntermedio"
        app:strokeWidth="2dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">
        <ImageButton
            android:id="@+id/btnHome"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/home_morado"
            android:contentDescription="Volver al inicio"
            android:padding="12dp"
            android:scaleType="centerInside" />
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardTituloMascota"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="20dp"
        app:cardBackgroundColor="@color/rectanguloLogo"
        app:cardCornerRadius="20dp"
        app:cardElevation="6dp"
        app:strokeColor="@color/colorIntermedio"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toTopOf="@id/btnHomeContainer"
        app:layout_constraintBottom_toBottomOf="@id/btnHomeContainer"
        app:layout_constraintStart_toEndOf="@id/btnHomeContainer"
        app:layout_constraintEnd_toEndOf="parent">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="Agregar mascota"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/black" />
    </com.google.android.material.card.MaterialCardView>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="15dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/btnHomeContainer"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="40dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginVertical="10dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="25dp"
                app:cardElevation="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:background="@drawable/rectangulosesion">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Datos de la mascota"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:layout_marginBottom="15dp"
                        android:textSize="15sp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutRuac"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:hintEnabled="false"
                        app:errorEnabled="true"
                        app:errorIconDrawable="@null">
                        <EditText
                            android:id="@+id/txtRuac"
                            android:layout_width="match_parent"
                            android:layout_height="55dp"
                            android:hint="Folio RUAC"
                            android:background="@drawable/campos_circulares"
                            android:paddingHorizontal="15dp"
                            android:textColor="@android:color/black"
                            android:inputType="textCapCharacters" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:id="@+id/txtTramitarRuac"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="-8dp"
                        android:layout_marginBottom="12dp"
                        android:layout_marginEnd="5dp"
                        android:padding="5dp"
                        android:text="¿No conoces su RUAC? Tramítalo aquí"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textStyle="bold|italic"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutNombreMascota"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:hintEnabled="false"
                        app:errorEnabled="true"
                        app:errorIconDrawable="@null">
                        <EditText
                            android:id="@+id/txtNombreMascota"
                            android:layout_width="match_parent"
                            android:layout_height="55dp"
                            android:hint="Nombre"
                            android:maxLength="50"
                            android:background="@drawable/campos_circulares"
                            android:paddingHorizontal="15dp"
                            android:textColor="@android:color/black"
                            android:inputType="textCapWords" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutFechaNacimiento"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:hintEnabled="false"
                        app:errorEnabled="true"
                        app:endIconTint="@color/moradoSubtitulo"
                        app:materialThemeOverlay="@style/ThemeOverlay.App.ExposedDropdownMenu"
                        app:errorIconDrawable="@null">
                        <AutoCompleteTextView
                            android:id="@+id/txtFechaNacimiento"
                            android:layout_width="match_parent"
                            android:layout_height="55dp"
                            android:hint="Fecha de nacimiento"
                            android:contentDescription="Seleccionar fecha de nacimiento o indicar si se desconoce"
                            android:background="@drawable/campos_circulares"
                            android:paddingHorizontal="15dp"
                            android:textColor="@android:color/black"
                            android:inputType="none"
                            android:focusable="false"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutFechaAdopcion"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:hintEnabled="false"
                        app:errorEnabled="true"
                        app:endIconTint="@color/moradoSubtitulo"
                        app:materialThemeOverlay="@style/ThemeOverlay.App.ExposedDropdownMenu"
                        app:errorIconDrawable="@null">
                        <AutoCompleteTextView
                            android:id="@+id/txtFechaAdopcion"
                            android:layout_width="match_parent"
                            android:layout_height="55dp"
                            android:hint="Fecha de adopción"
                            android:contentDescription="Seleccionar fecha de adopcion o indicar si se desconoce"
                            android:background="@drawable/campos_circulares"
                            android:paddingHorizontal="15dp"
                            android:textColor="@android:color/black"
                            android:inputType="none"
                            android:focusable="false"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutEspecie"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:hintEnabled="false"
                        app:errorEnabled="true"
                        app:endIconTint="@color/moradoSubtitulo"
                        app:materialThemeOverlay="@style/ThemeOverlay.App.ExposedDropdownMenu"
                        app:errorIconDrawable="@null">
                        <AutoCompleteTextView
                            android:id="@+id/txtEspecie"
                            android:layout_width="match_parent"
                            android:layout_height="55dp"
                            android:hint="Especie (Perro / Gato)"
                            android:contentDescription="Seleccionar especie de la mascota"                            android:background="@drawable/campos_circulares"
                            android:paddingHorizontal="15dp"
                            android:textColor="@android:color/black"
                            android:inputType="none"
                            android:focusable="false"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutRaza"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:hintEnabled="false"
                        app:errorEnabled="true"
                        app:endIconTint="@color/moradoSubtitulo"
                        app:materialThemeOverlay="@style/ThemeOverlay.App.ExposedDropdownMenu"
                        app:errorIconDrawable="@null">
                        <AutoCompleteTextView
                            android:id="@+id/txtRaza"
                            android:layout_width="match_parent"
                            android:layout_height="55dp"
                            android:hint="Raza"
                            android:contentDescription="Seleccionar raza de la mascota"
                            android:background="@drawable/campos_circulares"
                            android:paddingHorizontal="15dp"
                            android:textColor="@android:color/black"
                            android:inputType="none"
                            android:focusable="false"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutRazaOtro"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        app:hintEnabled="false"
                        app:errorEnabled="true"
                        app:errorIconDrawable="@null"
                        android:layout_marginTop="-10dp">
                        <EditText
                            android:id="@+id/txtRazaOtro"
                            android:layout_width="match_parent"
                            android:layout_height="55dp"
                            android:hint="Escribe la raza"
                            android:background="@drawable/campos_circulares"
                            android:paddingHorizontal="15dp"
                            android:textColor="@android:color/black"
                            android:inputType="textCapWords" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:id="@+id/txtIdentificarRaza"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="¿No conoces la raza? Identifícala aquí"
                        android:textColor="@color/white"
                        android:layout_gravity="center"
                        android:textStyle="bold"
                        android:visibility="gone"
                        android:padding="8dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutColor"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:hintEnabled="false"
                        app:errorEnabled="true"
                        app:endIconTint="@color/moradoSubtitulo"
                        app:materialThemeOverlay="@style/ThemeOverlay.App.ExposedDropdownMenu"
                        app:errorIconDrawable="@null">
                        <AutoCompleteTextView
                            android:id="@+id/txtColor"
                            android:layout_width="match_parent"
                            android:layout_height="55dp"
                            android:hint="Color"
                            android:contentDescription="Seleccionar color de la mascota o especificar otro"
                            android:background="@drawable/campos_circulares"
                            android:paddingHorizontal="15dp"
                            android:textColor="@android:color/black"
                            android:inputType="none"
                            android:focusable="false"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutOtroColor"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        app:hintEnabled="false"
                        app:errorEnabled="true"
                        app:errorIconDrawable="@null"
                        android:layout_marginTop="-10dp">
                        <EditText
                            android:id="@+id/txtOtroColor"
                            android:layout_width="match_parent"
                            android:layout_height="55dp"
                            android:hint="Especifica el color"
                            android:background="@drawable/campos_circulares"
                            android:paddingHorizontal="15dp"
                            android:textColor="@android:color/black"
                            android:inputType="textCapWords" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutSexo"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:hintEnabled="false"
                        app:errorEnabled="true"
                        app:endIconTint="@color/moradoSubtitulo"
                        app:materialThemeOverlay="@style/ThemeOverlay.App.ExposedDropdownMenu"
                        app:errorIconDrawable="@null">
                        <AutoCompleteTextView
                            android:id="@+id/txtSexo"
                            android:layout_width="match_parent"
                            android:layout_height="55dp"
                            android:hint="Sexo"
                            android:contentDescription="Seleccionar sexo de la mascota"
                            android:background="@drawable/campos_circulares"
                            android:paddingHorizontal="15dp"
                            android:textColor="@android:color/black"
                            android:inputType="none"
                            android:focusable="false"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/layoutPeso"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            app:hintEnabled="false"
                            app:errorEnabled="true"
                            app:errorIconDrawable="@null">
                            <EditText
                                android:id="@+id/txtPeso"
                                android:layout_width="match_parent"
                                android:layout_height="55dp"
                                android:hint="Peso (kg)"
                                android:inputType="numberDecimal"
                                android:background="@drawable/campos_circulares"
                                android:paddingHorizontal="15dp"
                                android:textColor="@android:color/black" />
                        </com.google.android.material.textfield.TextInputLayout>
                        <View android:layout_width="10dp" android:layout_height="1dp"/>
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/layoutEstatura"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            app:hintEnabled="false"
                            app:errorEnabled="true"
                            app:errorIconDrawable="@null">
                            <EditText
                                android:id="@+id/txtEstatura"
                                android:layout_width="match_parent"
                                android:layout_height="55dp"
                                android:hint="Estatura (cm)"
                                android:inputType="numberDecimal"
                                android:background="@drawable/campos_circulares"
                                android:paddingHorizontal="15dp"
                                android:textColor="@android:color/black" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutAlergias"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:hintEnabled="false"
                        app:errorEnabled="true"
                        app:errorIconDrawable="@null">
                        <EditText
                            android:id="@+id/txtAlergias"
                            android:layout_width="match_parent"
                            android:layout_height="55dp"
                            android:hint="Alergias (opcional)"
                            android:background="@drawable/campos_circulares"
                            android:paddingHorizontal="15dp"
                            android:textColor="@android:color/black"
                            android:inputType="textCapSentences" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutNotas"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:hintEnabled="false"
                        app:errorEnabled="true"
                        app:errorIconDrawable="@null">
                        <EditText
                            android:id="@+id/txtNotas"
                            android:layout_width="match_parent"
                            android:layout_height="100dp"
                            android:hint="Notas adicionales"
                            android:gravity="top"
                            android:inputType="textMultiLine"
                            android:background="@drawable/campos_circulares"
                            android:padding="12dp"
                            android:textColor="@android:color/black" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnFoto"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:text="Subir fotografía"
                        app:cornerRadius="25dp"
                        android:layout_marginTop="10dp"
                        android:textColor="@android:color/black"
                        android:backgroundTint="@color/botonRegistrarse" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="180dp"
                        android:layout_height="180dp"
                        android:layout_gravity="center"
                        android:layout_marginVertical="20dp"
                        app:cardCornerRadius="90dp"
                        app:cardElevation="4dp">
                        <ImageView
                            android:id="@+id/imgFotoMascota"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/foto_blanco" />
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGuardarMascota"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:text="Guardar mascota"
                        android:textSize="16sp"
                        app:cornerRadius="30dp"
                        android:textStyle="bold"
                        android:textColor="@android:color/black"
                        android:backgroundTint="@color/colorIntermedio"
                        android:layout_marginTop="10dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>